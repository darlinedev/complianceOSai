# 🛡️ Configuration Supabase - ComplianceOS
# Remplissez ces valeurs avec vos identifiants du Dashboard Supabase (https://database.new)

# URL publique de votre projet Supabase (ex: https://abcde12345.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Clé publique anonyme (Anon Key) utilisable côté client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
